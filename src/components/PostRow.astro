---
import DifficultyBadge from "./DifficultyBadge.astro";
import TagBadge from "./TagBadge.astro";
import { formatDateEN, formatDateCN } from "../utils/dateHelper";
import type { Post } from "../types";

interface Props {
    post: Post;
}

const { post } = Astro.props;


const dateEN = formatDateEN(new Date(post.date).toISOString().split('T')[0]);
const dateCN = formatDateCN(new Date(post.date).toISOString().split('T')[0]);
---

<div
    class="file-row post-list-grid"
    data-post-id={post.id}
    data-en-title={post.enTitle}
>
    <!-- Title -->
    <div class="col-title">
        <div class="title-container">
            <svg
                class="file-icon"
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
            >
                <path
                    d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"
                ></path>
                <polyline points="14 2 14 8 20 8"></polyline>
                <line x1="16" y1="13" x2="8" y2="13"></line>
                <line x1="16" y1="17" x2="8" y2="17"></line>
                <polyline points="10 9 9 9 8 9"></polyline>
            </svg>

            <a class="post-link" href={`/${post.slug}`}>
                <span
                    class="title-text"
                    data-cn={post.title}
                    data-en={post.enTitle}
                >
                    {post.title}
                </span>
            </a>
        </div>
    </div>

    <!-- Difficulty -->
    <div class="col-difficulty">
        <DifficultyBadge difficulty={post.difficulty} />
    </div>

    <!-- Tags -->
    <div class="col-tags">
        <div class="tags-wrapper">
            {post.tagEN.map((tag: string) => <TagBadge tag={tag} />)}
        </div>
    </div>

    <!-- Date -->
    <div class="col-date" data-cn={dateCN} data-en={dateEN}>
        {dateCN}
    </div>
</div>

